stroke.Thickness = 2
stroke.Parent = panel

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 35)
title.BackgroundColor3 = TITLE_COLOR
title.Text = "Kaiblu Script - Xeno"
title.TextColor3 = Color3.new(1,1,1)
title.TextSize = 14
title.Font = Enum.Font.GothamBold
title.Parent = panel
Instance.new("UICorner", title).CornerRadius = UDim.new(0, 12)

local y = 45
local function createToggle(name, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 38)
    btn.Position = UDim2.new(0.05, 0, 0, y)
    btn.BackgroundColor3 = BUTTON_BASE
    btn.Text = name .. " [OFF]"
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 13
    btn.Parent = panel
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.Text = name .. (active and " [ON]" or " [OFF]")
        btn.BackgroundColor3 = active and BUTTON_ON or BUTTON_BASE
        callback(active)
    end)
    
    if name == "Heal Up" then
        healUpButton = btn
    end
    
    y += 48
end

-- Create Toggles
createToggle("Auto Punch", autoPunchFeature)
createToggle("Headlock", headlockFeature)
createToggle("Auto Weight", autoWeightFeature)
createToggle("Auto Drag", autoDragFeature)
createToggle("Auto Press T", autoPressTFeature)
createToggle("Heal Up", healUpFeature)
createToggle("Auto Escape", autoEscapeFeature)
createToggle("Auto Push (Always)", autoPushFeature)
createToggle("Auto Stomp (On Top)", autoStompFeature)

