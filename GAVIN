-- Kaiblu Script | PC Version for Xeno Executor
-- Press V to Hide/Show GUI | Press C to Toggle Heal Up
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TweenService = game:GetService("TweenService")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ==================== ADONIS BYPASS ====================
local getinfo = getinfo or debug.getinfo
local DEBUG = false
local Detected, Kill
setthreadidentity(2)
for i, v in getgc(true) do
    if typeof(v) == "table" then
        local DetectFunc = rawget(v, "Detected")
        local KillFunc = rawget(v, "Kill")
      
        if typeof(DetectFunc) == "function" and not Detected then
            Detected = DetectFunc
            hookfunction(Detected, function(Action, Info, NoCrash)
                if Action ~= "_" then
                    if DEBUG then warn("Adonis flagged: " .. Action) end
                end
                return true
            end)
        end
      
        if rawget(v, "Variables") and rawget(v, "Process") and typeof(KillFunc) == "function" and not Kill then
            Kill = KillFunc
            hookfunction(Kill, function(Info)
                if DEBUG then warn("Adonis tried to kill: " .. Info) end
            end)
        end
    end
end
setthreadidentity(7)
-- ==================== END BYPASS ====================
task.wait(2)

-- ==================== VARIABLES ====================
local char = player.Character or player.CharacterAdded:Wait()
player.CharacterAdded:Connect(function(c) char = c end)

-- ==================== COLORS ====================
local PANEL_COLOR = Color3.fromRGB(20, 30, 55)
local TITLE_COLOR = Color3.fromRGB(10, 25, 70)
local STROKE_COLOR = Color3.fromRGB(0, 170, 255)
local BUTTON_BASE = Color3.fromRGB(35, 50, 90)
local BUTTON_ON = Color3.fromRGB(0, 140, 255)
local taskHandles = {}
local guiVisible = true

-- ==================== NOTIFICATION SYSTEM ====================
local notifications = {}
local function showNotification(text, isOn)
    local status = isOn and "Enabled" or "Disabled"
    local color = isOn and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(200, 50, 50)
    
    local notif = Instance.new("TextLabel")
    notif.Size = UDim2.new(0, 240, 0, 42)
    notif.Position = UDim2.new(1, -260, 1, -70 - (#notifications * 52))
    notif.BackgroundColor3 = Color3.fromRGB(20, 30, 55)
    notif.Text = isOn and "✅ " .. text or "❌ " .. text
    notif.TextColor3 = color
    notif.TextSize = 14
    notif.Font = Enum.Font.GothamSemibold
    notif.BackgroundTransparency = 0.25
    notif.TextStrokeTransparency = 0.6
    notif.Parent = playerGui

    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 8)

    table.insert(notifications, notif)

    task.delay(2, function()
        if notif and notif.Parent then
            TweenService:Create(notif, TweenInfo.new(0.7), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
            task.wait(0.7)
            notif:Destroy()
            table.remove(notifications, table.find(notifications, notif) or 0)
        end
    end)
end

-- ==================== HEAL UP (Toggleable) ====================
local healUpEnabled = false
local healUpButton = nil  -- Will store reference to GUI button

local function healUpFeature(state)
    healUpEnabled = state
    if healUpButton then
        healUpButton.Text = "Heal Up " .. (state and "[ON]" or "[OFF]")
        healUpButton.BackgroundColor3 = state and BUTTON_ON or BUTTON_BASE
    end
    showNotification("Heal Up", state)
    
    if state then
        task.spawn(function()
            while healUpEnabled do
                ReplicatedStorage.events.SoloPlrEvents:FireServer("Health")
                task.wait(1.2)
            end
        end)
    end
end

