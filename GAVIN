-- ==================== AUTO PRESS T (2 seconds) ====================
local function autoPressTFeature(state)
    showNotification("Auto Press T", state)
    if state then
        taskHandles.pressT = task.spawn(function()
            while true do
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.T, false, game)
                task.wait(0.1)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.T, false, game)
                task.wait(00000)   -- Back to 2 seconds
            end
        end)
    else
        if taskHandles.pressT then task.cancel(taskHandles.pressT) taskHandles.pressT = nil end
    end
end

local function headlockFeature(state)
    showNotification("Headlock", state)
    if state then
        taskHandles.headlock = task.spawn(function()
            local mainKeys = ReplicatedStorage:WaitForChild("events"):WaitForChild("MainKeys")
            while true do
                pcall(function()
                    mainKeys:FireServer("DamageTool")
                end)
                task.wait(0.08)
            end
        end)
    else
        if taskHandles.headlock then task.cancel(taskHandles.headlock) taskHandles.headlock = nil end
    end
end

local function autoStompFeature(state)
    showNotification("Auto Stomp", state)
    if state then
        taskHandles.stomp = task.spawn(function()
            local humanoid = char:WaitForChild("Humanoid")
            local animator = humanoid:WaitForChild("Animator")
            local stompAnim = Instance.new("Animation")
            stompAnim.AnimationId = "rbxassetid://16069201225"
            local track = animator:LoadAnimation(stompAnim)
            track.Looped = false
            local mainKeys = ReplicatedStorage:WaitForChild("events"):WaitForChild("MainKeys")
           
            while true do
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, otherPlayer in pairs(Players:GetPlayers()) do
                        if otherPlayer ~= player and otherPlayer.Character then
                            local otherHrp = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
                            if otherHrp then
                                local dist = (hrp.Position - otherHrp.Position).Magnitude
                                if dist < 8 and hrp.Position.Y > otherHrp.Position.Y + 2 then
                                    track:Play()
                                    mainKeys:FireServer("Stomp")
                                    task.wait(5)
                                    break
                                end
                            end
                        end
                    end
                end
                task.wait(0.2)
            end
        end)
    else
        if taskHandles.stomp then task.cancel(taskHandles.stomp) taskHandles.stomp = nil end
    end
end

local function autoEscapeFeature(state)
    showNotification("Auto Escape", state)
    if state then
        taskHandles.autoescape = task.spawn(function()
            local ev = ReplicatedStorage:WaitForChild("events"):WaitForChild("ValueChange")
            while true do
                local success, escaped = pcall(function()
                    return char and char:FindFirstChild("Player") and char.Player:FindFirstChild("Damages") and char.Player.Damages:FindFirstChild("values") and char.Player.Damages.values:FindFirstChild("DamageTool") and char.Player.Damages.values.DamageTool:FindFirstChild("Escaped")
                end)
                if success and escaped then
                    ev:FireServer(escaped, true)
                end
                task.wait(0.01)
            end
        end)
    else
        if taskHandles.autoescape then task.cancel(taskHandles.autoescape) taskHandles.autoescape = nil end
    end
end

-- ==================== C KEYBIND FOR HEAL UP ====================
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.C then
        healUpEnabled = not healUpEnabled
        healUpFeature(healUpEnabled)
    end
end)

