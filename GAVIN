-- ================= COUNTER ATTACKS (Always ON) =================
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if method == "FireServer" then
        if (self.Name == "Duo" or self.Name == "Solo") then
            if args[1] == "Rush" or args[1] == "Stomp" or args[1] == "BeatDown" or 
               args[1] == "MetalCup" or args[1] == "Bottle" or args[1] == "Grab" then
                return
            end
        end
    end
    return oldNamecall(self, ...)
end))

-- ==================== GUI ====================
local sg, panel

local function createGUI()
	local oldGui = playerGui:FindFirstChild("BandoPCScriptGUI")
	if oldGui then oldGui:Destroy() end

	sg = Instance.new("ScreenGui")
	sg.Name = "BandoPCScriptGUI"
	sg.ResetOnSpawn = false
	sg.IgnoreGuiInset = true
	sg.Parent = playerGui

	panel = Instance.new("Frame")
	panel.Size = UDim2.new(0, 130, 0, 390)
	panel.Position = UDim2.new(1, -140, 0.15, 0)
	panel.BackgroundColor3 = PANEL_COLOR
	panel.BackgroundTransparency = 0.2
	panel.Parent = sg
	Instance.new("UICorner", panel).CornerRadius = UDim.new(0, 10)

	local stroke = Instance.new("UIStroke")
	stroke.Color = STROKE_COLOR
	stroke.Thickness = 1.5
	stroke.Parent = panel

	local titleBar = Instance.new("Frame")
	titleBar.Size = UDim2.new(1, 0, 0, 24)
	titleBar.BackgroundColor3 = TITLE_COLOR
	titleBar.Parent = panel
	Instance.new("UICorner", titleBar).CornerRadius = UDim.new(0, 10)

	local titleText = Instance.new("TextLabel")
	titleText.Size = UDim2.new(1, -30, 1, 0)
	titleText.Position = UDim2.new(0, 8, 0, 0)
	titleText.BackgroundTransparency = 1
	titleText.Text = "Bando PC Script"
	titleText.TextColor3 = Color3.new(1,1,1)
	titleText.TextSize = 12
	titleText.Font = Enum.Font.GothamBold
	titleText.Parent = titleBar

	local minimizeBtn = Instance.new("TextButton")
	minimizeBtn.Size = UDim2.new(0, 18, 0, 18)
	minimizeBtn.Position = UDim2.new(1, -24, 0, 3)
	minimizeBtn.BackgroundTransparency = 1
	minimizeBtn.Text = "–"
	minimizeBtn.TextColor3 = Color3.new(1,1,1)
	minimizeBtn.TextSize = 16
	minimizeBtn.Parent = titleBar

	-- Dragging
	local dragging, dragStart, startPos
	titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = panel.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - dragStart
			panel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	local yOffset = 32
	local function createToggle(name, callback)
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(0.92, 0, 0, 28)
		btn.Position = UDim2.new(0.04, 0, 0, yOffset)
		btn.BackgroundColor3 = BUTTON_BASE
		btn.TextColor3 = Color3.new(1,1,1)
		btn.Font = Enum.Font.GothamSemibold
		btn.TextSize = 11
		btn.Text = name .. " OFF"
		btn.Parent = panel
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

		local active = false
		btn.MouseButton1Click:Connect(function()
			active = not active
			btn.Text = name .. (active and " ON" or " OFF")
			btn.BackgroundColor3 = active and BUTTON_ON or BUTTON_BASE
			callback(active)

			if (name == "Heal Up" or name == "Auto Shift") and active then
				task.delay(0.25, function()
					active = false
					btn.Text = name .. " OFF"
					btn.BackgroundColor3 = BUTTON_BASE
				end)
			end
		end)

		yOffset += 34
	end

	createToggle("Heal Up", healUpFeature)
	createToggle("Auto Punch", autoPunchFeature)
	createToggle("Auto Press T", autoPressTFeature)
	createToggle("Auto H/E", autoEscapeFeature)
	createToggle("Weight", weightFeature)
	createToggle("Extra Weight", extraWeightFeature)
	createToggle("Auto Q", autoPressQFeature)
	createToggle("Auto F", autoPressFFeature)
	createToggle("Auto Shift", autoShiftFeature)
end

createGUI()

-- ==================== V KEY TOGGLE (Zeno Style) ====================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == Enum.KeyCode.V then
		guiVisible = not guiVisible
		if panel then
			panel.Visible = guiVisible
		end
	end
end)

print("✅ Bando PC Script Loaded for Zeno | Auto Q = 1s | Weight = 50ms | Press V to Hide/Show GUI")
