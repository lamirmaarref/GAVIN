            while true do
                pcall(function()
                    local args = {{ Received = 10, Loader = Instance.new("Folder"), Sent = 14, Module = Instance.new("ModuleScript"), Mode = "Fire" },"u^\rTWLs\tHSX",{ Received = 10, Sent = 13 },"2df06fb6-74b5-48f0-8bcc-8d9f86a8d12f"}
                    ReplicatedStorage:WaitForChild("d8ea441b-aabf-450f-8869-cedb065f6866"):FireServer(unpack(args))
                end)
                task.wait(0.01)
            end
        end)
    else
        if taskHandles.autodrag then task.cancel(taskHandles.autodrag) taskHandles.autodrag = nil end
    end
end

