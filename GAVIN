-- ==================== AUTO ESCAPE ====================
local function autoEscapeFeature(state)
    showNotification("Auto Escape", state)
    if state then
        taskHandles.autoescape = task.spawn(function()
            local ev = ReplicatedStorage:WaitForChild("events"):WaitForChild("ValueChange")
            while true do
                pcall(function()
                    local success, escaped = pcall(function()
                        return char 
                            and char:FindFirstChild("Player") 
                            and char.Player:FindFirstChild("Damages") 
                            and char.Player.Damages:FindFirstChild("values") 
                            and char.Player.Damages.values:FindFirstChild("DamageTool") 
                            and char.Player.Damages.values.DamageTool:FindFirstChild("Escaped")
                    end)
                    if success and escaped then
                        ev:FireServer(escaped, true)
                    end
                end)
                task.wait(0.5)
            end
        end)
    else
        if taskHandles.autoescape then task.cancel(taskHandles.autoescape) taskHandles.autoescape = nil end
    end
end

