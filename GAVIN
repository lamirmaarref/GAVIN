-- SERVICES
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ==================== ZENO OPTIMIZED ADONIS BYPASS ====================
local DEBUG = false

setthreadidentity(2)

for i, v in getgc(true) do
    if typeof(v) == "table" then
        local DetectFunc = rawget(v, "Detected")
        local KillFunc = rawget(v, "Kill")
        
        if typeof(DetectFunc) == "function" then
            hookfunction(DetectFunc, function(Action, Info, NoCrash)
                if Action ~= "_" then
                    if DEBUG then warn("Adonis flagged: " .. tostring(Action)) end
                end
                return true
            end)
        end
        
        if typeof(KillFunc) == "function" then
            hookfunction(KillFunc, function(Info)
                if DEBUG then warn("Adonis tried to kill: " .. tostring(Info)) end
            end)
        end
    end
end

setthreadidentity(7)
-- ==================== END OF ZENO BYPASS ====================

task.wait(3)

-- ==================== COLORS (Pink & Light Blue Theme) ====================
local PANEL_COLOR = Color3.fromRGB(255, 182, 193)
local TITLE_COLOR = Color3.fromRGB(255, 105, 180)
local STROKE_COLOR = Color3.fromRGB(135, 206, 250)
local BUTTON_BASE = Color3.fromRGB(255, 200, 220)
local BUTTON_ON = Color3.fromRGB(255, 110, 180)

-- STATE VARIABLES
local taskHandles = {}
local guiVisible = true

-- ==================== CHARACTER SETUP ====================
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid", 5)

player.CharacterAdded:Connect(function(newChar)
	character = newChar
	humanoid = newChar:WaitForChild("Humanoid", 5)
end)

-- ==================== FEATURES ====================
local AnimationSystem
pcall(function()
    AnimationSystem = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("AnimationSystem"))
end)

local function weightFeature(state)
	if state then
		taskHandles.weight = task.spawn(function()
			while true do
				pcall(function()
					if AnimationSystem and player.Character then
						AnimationSystem.PlayAnimation(player.Character, "Weight")
					end
					local MainKeys = ReplicatedStorage:WaitForChild("events"):WaitForChild("MainKeys")
					MainKeys:FireServer("WeightOn")
				end)
				task.wait(0.05)
			end
		end)
	else
		if taskHandles.weight then task.cancel(taskHandles.weight) taskHandles.weight = nil end
	end
end

local function extraWeightFeature(state)
	if state then
		taskHandles.extraWeight = task.spawn(function()
			while true do
				pcall(function()
					if not character or not character.Parent then return end
					if humanoid and humanoid.Health <= 0 then return end
					
					local MainKeys = ReplicatedStorage:WaitForChild("events"):WaitForChild("MainKeys")
					if MainKeys then MainKeys:FireServer("Weight") end
				end)
				task.wait(0.8)
			end
		end)
	else
		if taskHandles.extraWeight then task.cancel(taskHandles.extraWeight) taskHandles.extraWeight = nil end
	end
end

local function autoEscapeFeature(state)
	if state then
		taskHandles.headlock = task.spawn(function()
			while true do
				pcall(function()
					local mainKeys = ReplicatedStorage:WaitForChild("events"):WaitForChild("MainKeys")
					mainKeys:FireServer("DamageTool")
				end)
				task.wait(0.1)
			end
		end)
		
		taskHandles.escape = task.spawn(function()
			while true do
				pcall(function()
					local damages = character:FindFirstChild("Player") and character.Player:FindFirstChild("Damages")
					if damages then
						local values = damages:FindFirstChild("values")
						if values then
							local damageTool = values:FindFirstChild("DamageTool")
							if damageTool then
								local escaped = damageTool:FindFirstChild("Escaped")
								if escaped and ReplicatedStorage.events:FindFirstChild("ValueChange") then
									ReplicatedStorage.events.ValueChange:FireServer(escaped, true)
								end
							end
						end
					end
				end)
				task.wait(0.1)
			end
		end)
	else
		if taskHandles.headlock then task.cancel(taskHandles.headlock) taskHandles.headlock = nil end
		if taskHandles.escape then task.cancel(taskHandles.escape) taskHandles.escape = nil end
	end
end

local function autoPressQFeature(state)
	if state then
		taskHandles.pressQ = task.spawn(function()
			while true do
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
				task.wait()
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
				task.wait(1)
			end
		end)
	else
		if taskHandles.pressQ then task.cancel(taskHandles.pressQ) taskHandles.pressQ = nil end
	end
end

